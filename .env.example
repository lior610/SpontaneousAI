# External PostgreSQL database
POSTGRES_HOST=db_ip
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=postgres
POSTGRES_ATTRACTIONS_DB=attractions
POSTGRES_USERS_DB=client_info

# Engine URL (for API to reach Attraction Engine)
# Use "localhost" when running services locally; use "engine" when using docker-compose
ENGINE_HOST=localhost
ENGINE_PORT=8000

RANKING_WEIGHT_SEMANTIC=0.40
RANKING_WEIGHT_HOURS=0.10
RANKING_WEIGHT_DISTANCE=0.15
RANKING_WEIGHT_BUDGET=0.10
RANKING_WEIGHT_POPULARITY=0.20
RANKING_WEIGHT_DIVERSITY=0.05

# Ranking Penalties
RANKING_CLUSTER_PENALTY=0.5
