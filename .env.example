# External PostgreSQL database
POSTGRES_HOST=10.10.248.114
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password_here
POSTGRES_DB=postgres
POSTGRES_ATTRACTIONS_DB=attractions
POSTGRES_USERS_DB=client_info

# OpenTripMap API (free key from https://dev.opentripmap.org)
OPENTRIPMAP_API_KEY=api_key_here

# Engine URL (for API to reach Attraction Engine)
# Use "localhost" when running services locally; use "engine" when using docker-compose
ENGINE_HOST=localhost
ENGINE_PORT=8000

# PreferenceComposer — trip-setup blend: category embeddings vs qualifier text (ideally sum to 1.0)
PREF_WEIGHT_TRIP_SETUP_CATEGORIES=0.8
PREF_WEIGHT_TRIP_SETUP_QUALIFIERS=0.2
